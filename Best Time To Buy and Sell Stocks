Optimal solution 

int bestDay(vector<int> &p)
{
   int mini=p[0];
   int profit=0;
   int ind=0;
   for(int i=1;i<p.size();i++)
   {
       int cost=p[i]-mini;
       profit=max(cost,profit);
       if(cost==profit)
       {
           ind=i;
       }
       mini=min(p[i],mini);
   }
   return ind+1;
}
